#!/usr/bin/env bash

# https://github.com/bitwarden/clients/blob/main/apps/cli/examples/git-credential-bw.sh
# Compatible with bash 3.2+ (macOS system bash)

if [[ "$1" == "get" ]]; then
    protocol=""
    host=""

    read -r line
    while [ -n "$line" ]; do
        key=${line%%=*}
        value=${line#*=}
        case "$key" in
            protocol) protocol=$value ;;
            host)     host=$value ;;
        esac
        read -r line
    done

    if [[ "$protocol" != "https" ]]; then
        exit
    fi

    if [[ -z "$host" ]]; then
        exit
    fi

    if ! bw list items --search "asdf" > /dev/null 2>&1; then
        echo "Please login to Bitwarden to use git credential helper" > /dev/stderr
        exit
    fi

    id=$(bw list items --search "$host" | jq ".[] | select(.name == \"$host\").id" -r)

    if [[ -z "$id" ]]; then
        echo "Couldn't find item id in Bitwarden DB." > /dev/stderr
        exit
    fi

    user=$(bw get username "$id")
    pass=$(bw get password "$id")

    if [[ -z "$user" ]] || [[ -z "$pass" ]]; then
        echo "Couldn't find host in Bitwarden DB." > /dev/stderr
        exit
    fi

    echo username="$user"
    echo password="$pass"
fi
