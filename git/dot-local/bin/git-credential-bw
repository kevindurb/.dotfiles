#!/usr/bin/env bash

if [[ "$1" != "get" ]]; then
    exit 0
fi

protocol=""
host=""

read -r line
while [ -n "$line" ]; do
    key=${line%%=*}
    value=${line#*=}
    case "$key" in
        protocol) protocol=$value ;;
        host)     host=$value ;;
    esac
    read -r line
done

if [[ "$protocol" != "https" ]] || [[ -z "$host" ]]; then
    exit 0
fi

# Check that bw is unlocked. `bw status` is cheap and never prompts.
# It returns JSON; we want status == "unlocked".
status=$(bw status 2>/dev/null | jq -r '.status' 2>/dev/null)

if [[ "$status" != "unlocked" ]]; then
    echo "git-credential-bw: Bitwarden is '$status'. Run: export BW_SESSION=\$(bw unlock --raw)" >&2
    exit 0
fi

id=$(bw list items --search "$host" 2>/dev/null | jq -r ".[] | select(.name == \"$host\").id")

if [[ -z "$id" ]]; then
    echo "git-credential-bw: No item named '$host' in vault" >&2
    exit 0
fi

user=$(bw get username "$id" 2>/dev/null)
pass=$(bw get password "$id" 2>/dev/null)

if [[ -z "$user" ]] || [[ -z "$pass" ]]; then
    echo "git-credential-bw: Item '$host' missing username or password" >&2
    exit 0
fi

echo "username=$user"
echo "password=$pass"
