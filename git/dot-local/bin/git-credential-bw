#!/usr/bin/env bash

if [[ "$1" != "get" ]]; then
    exit 0
fi

protocol=""
host=""

read -r line
while [ -n "$line" ]; do
    key=${line%%=*}
    value=${line#*=}
    case "$key" in
        protocol) protocol=$value ;;
        host)     host=$value ;;
    esac
    read -r line
done

if [[ "$protocol" != "https" ]] || [[ -z "$host" ]]; then
    exit 0
fi

# rbw unlocked exits non-zero if locked/logged out, without prompting.
if ! rbw unlocked 2>/dev/null; then
    echo "git-credential-bw: Bitwarden is locked. Run: rbw unlock" >&2
    exit 0
fi

entry=$(rbw get --raw "$host" 2>/dev/null)

if [[ -z "$entry" ]]; then
    echo "git-credential-bw: No item named '$host' in vault" >&2
    exit 0
fi

user=$(printf '%s' "$entry" | jq -r '.data.username // empty')
pass=$(printf '%s' "$entry" | jq -r '.data.password // empty')

if [[ -z "$user" ]] || [[ -z "$pass" ]]; then
    echo "git-credential-bw: Item '$host' missing username or password" >&2
    exit 0
fi

echo "username=$user"
echo "password=$pass"
