Host github.com
  HostName ssh.github.com
  Port 443

Host steamdeck
  User deck

ServerAliveInterval 5
ServerAliveCountMax 1
# DevPod Start teardrop.devpod
Host teardrop.devpod
  ForwardAgent yes
  LogLevel error
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  ProxyCommand /Applications/DevPod.app/Contents/MacOS/devpod-cli ssh --stdio --context default --user vscode teardrop
  User vscode
# DevPod End teardrop.devpod