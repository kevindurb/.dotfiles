Include ~/.devpod/ssh_config.d/*

Host github.com
  HostName ssh.github.com
  Port 443

Host steamdeck
  User deck

ServerAliveInterval 5
ServerAliveCountMax 1
# DevPod Start dotfiles.devpod
Host dotfiles.devpod
  ForwardAgent yes
  LogLevel error
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  ProxyCommand /Users/kevindurbin/.local/bin/devpod ssh --stdio --context default --user kevindurb dotfiles
  User kevindurb
# DevPod End dotfiles.devpod